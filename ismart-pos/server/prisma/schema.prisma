// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Product {
  id           Int           @id @default(autoincrement())
  name         String
  upc          String?
  isSerialized Boolean       @default(false)
  costPrice    Float         @default(0)
  sellPrice    Float         @default(0)
  quantity     Int           @default(0)
  createdAt    DateTime      @default(now())
  units        ProductUnit[]
  saleItems    SaleItem[]
}

// One row = one physical phone unit. Only used when Product.isSerialized = true.
// Stock level for serialized products is derived: count units where status = "in_stock".
model ProductUnit {
  id         Int       @id @default(autoincrement())
  product    Product   @relation(fields: [productId], references: [id])
  productId  Int
  imei       String    @unique
  // Lifecycle: in_stock → sold | returned | defective
  status     String    @default("in_stock")
  costPrice  Float     @default(0)
  receivedAt DateTime  @default(now())
  saleItem   SaleItem?
}

// A customer of the shop. Phone is the unique identifier — used to look up returning customers.
model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?  @unique
  email     String?
  createdAt DateTime @default(now())
  sales     Sale[]
}

// One Sale = one checkout transaction. totalPrice is a snapshot, not recomputed later.
// Customer is optional — anonymous walk-in sales have customerId = null.
model Sale {
  id         Int        @id @default(autoincrement())
  totalPrice Float
  createdAt  DateTime   @default(now())
  customer   Customer?  @relation(fields: [customerId], references: [id])
  customerId Int?
  items      SaleItem[]
}

// One row per line in the cart. unitPrice is copied from Product.sellPrice at sale time.
model SaleItem {
  id            Int          @id @default(autoincrement())
  sale          Sale         @relation(fields: [saleId], references: [id])
  saleId        Int
  product       Product      @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId     Int
  // Only set for serialized phones; null for accessories.
  unit          ProductUnit? @relation(fields: [productUnitId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productUnitId Int?         @unique
  unitPrice     Float
  quantity      Int          @default(1)
}